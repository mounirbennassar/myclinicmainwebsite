# Copy to `.env` next to docker-compose.yml on the server and fill in.
# The same file feeds all three containers (and the web image build).

# ── Postgres (runs as the `db` container, data in the pgdata volume) ────────
POSTGRES_USER=myclinic
POSTGRES_PASSWORD=change-me-to-a-long-random-string
POSTGRES_DB=myclinic
# Host port Postgres is published on (loopback only). Change if 5432 is busy,
# and keep DATABASE_URL_BUILD below in sync.
POSTGRES_PORT=5432

# Runtime connection (containers reach Postgres via the `db` service name).
# Keep user/password/db in sync with the POSTGRES_* values above.
DATABASE_URL=postgresql://myclinic:change-me-to-a-long-random-string@db:5432/myclinic

# Build-time connection (the web image build pre-renders doctor pages; it
# reaches Postgres through the loopback port published by the db service).
DATABASE_URL_BUILD=postgresql://myclinic:change-me-to-a-long-random-string@127.0.0.1:5432/myclinic

# ── Portal subdomain ─────────────────────────────────────────────────────────
# Where the dashboard lives. When set, the main site redirects /login and
# /dashboard/* to this origin. Leave empty to serve the dashboard on the main
# domain (e.g. local development).
PORTAL_URL=https://portal.myclinic.com.sa

# ── App secrets ──────────────────────────────────────────────────────────────
# Secret used to sign session JWTs. Must stay the same across deploys or
# every dashboard user gets logged out.
JWT_SECRET=change-me-to-a-long-random-string

# Anantya.ai WhatsApp Business API gateway (dashboard WhatsApp tools).
ANANTYA_BASE_URL=https://apiv1.anantya.ai
ANANTYA_API_KEY=

# ── Staging overrides (leave unset in production) ───────────────────────────
# A second compose project (e.g. /opt/myclinic-staging) sets these so both
# stacks coexist on one server. See docs/VM-Deployment-Guide.md, "Staging".
#WEB_IMAGE=myclinic-web-staging
#WEB_BIND=0.0.0.0:3100
#PORTAL_BIND=0.0.0.0:3101
