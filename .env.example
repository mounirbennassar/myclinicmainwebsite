# Copy to `.env` next to docker-compose.yml on the server and fill in.
# The same file feeds both containers (and the web image build).

# Neon Postgres connection string (required — also used at build time to
# statically generate the doctor pages).
DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require

# Secret used to sign session JWTs. Must stay the same across deploys or
# every dashboard user gets logged out.
JWT_SECRET=change-me-to-a-long-random-string

# Anantya.ai WhatsApp Business API gateway (dashboard WhatsApp tools).
ANANTYA_BASE_URL=https://apiv1.anantya.ai
ANANTYA_API_KEY=
